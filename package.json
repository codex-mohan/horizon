{
  "name": "horizon",
  "version": "2.0.0",
  "private": true,
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "bun --cwd apps/web dev",
    "dev:relay": "bun --cwd apps/relay dev",
    "dev:all": "bun run scripts/dev-server.ts",
    "build": "turbo build",
    "lint": "ultracite check .",
    "lint:fix": "ultracite fix .",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "clean": "turbo clean",
    "health-check": "bun run scripts/health-check.ts",
    "load-test": "bun run scripts/load-test.ts"
  },
  "overrides": {},
  "devDependencies": {
    "turbo": "^2.9.8",
    "typescript": "^6.0.3",
    "ultracite": "^7.6.3"
  }
}
