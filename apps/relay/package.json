{
  "name": "@horizon/relay",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "tsc",
    "start": "bun src/index.ts",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "clean": "rm -rf dist .turbo drizzle"
  },
  "dependencies": {
    "@horizon/agent": "workspace:*",
    "@horizon/types": "workspace:*",
    "@horizon/utils": "workspace:*",
    "@singularity-ai/spectra-agent": "^0.3.0",
    "@singularity-ai/spectra-ai": "^0.3.0",
    "@singularity-ai/spectra-app": "^0.3.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.0",
    "bullmq": "^5.76.5",
    "chalk": "^5.6.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.16",
    "ioredis": "^5.10.1",
    "jose": "^6.2.3",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "prom-client": "^15.1.3",
    "stripe": "^22.1.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5"
  }
}
