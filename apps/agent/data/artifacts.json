    {
      "id": "artifact-1772782422317-485lxj",
      "threadId": "a66c0d2e-6e8a-4e67-9e61-4c084284adba",
      "title": "Ember & Grind Coffee Logo",
      "fileName": "coffee-logo.svg",
      "type": "svg",
      "content": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 200 200\" width=\"200\" height=\"200\">\n  <defs>\n    <!-- Main gradient for the cup -->\n    <linearGradient id=\"cupGradient\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"100%\">\n      <stop offset=\"0%\" style=\"stop-color:#5c3d2e\"/>\n      <stop offset=\"100%\" style=\"stop-color:#2c1810\"/>\n    </linearGradient>\n    \n    <!-- Coffee liquid gradient -->\n    <linearGradient id=\"coffeeGradient\" x1=\"0%\" y1=\"0%\" x2=\"0%\" y2=\"100%\">\n      <stop offset=\"0%\" style=\"stop-color:#8b5a3c\"/>\n      <stop offset=\"100%\" style=\"stop-color:#5c3d2e\"/>\n    </linearGradient>\n    \n    <!-- Accent gradient -->\n    <linearGradient id=\"accentGradient\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"100%\">\n      <stop offset=\"0%\" style=\"stop-color:#d4a574\"/>\n      <stop offset=\"100%\" style=\"stop-color:#8b5a3c\"/>\n    </linearGradient>\n    \n    <!-- Steam gradient -->\n    <linearGradient id=\"steamGradient\" x1=\"0%\" y1=\"100%\" x2=\"0%\" y2=\"0%\">\n      <stop offset=\"0%\" style=\"stop-color:rgba(255,255,255,0)\"/>\n      <stop offset=\"50%\" style=\"stop-color:rgba(255,255,255,0.4)\"/>\n      <stop offset=\"100%\" style=\"stop-color:rgba(255,255,255,0)\"/>\n    </linearGradient>\n    \n    <!-- Glow filter -->\n    <filter id=\"glow\" x=\"-20%\" y=\"-20%\" width=\"140%\" height=\"140%\">\n      <feGaussianBlur stdDeviation=\"3\" result=\"coloredBlur\"/>\n      <feMerge>\n        <feMergeNode in=\"coloredBlur\"/>\n        <feMergeNode in=\"SourceGraphic\"/>\n      </feMerge>\n    </filter>\n    \n    <!-- Shadow filter -->\n    <filter id=\"shadow\" x=\"-20%\" y=\"-20%\" width=\"140%\" height=\"140%\">\n      <feDropShadow dx=\"2\" dy=\"4\" stdDeviation=\"4\" flood-color=\"#2c1810\" flood-opacity=\"0.3\"/>\n    </filter>\n  </defs>\n  \n  <!-- Background circle -->\n  <circle cx=\"100\" cy=\"100\" r=\"95\" fill=\"#f5f0e8\"/>\n  <circle cx=\"100\" cy=\"100\" r=\"95\" fill=\"url(#accentGradient)\" opacity=\"0.1\"/>\n  \n  <!-- Outer ring -->\n  <circle cx=\"100\" cy=\"100\" r=\"88\" fill=\"none\" stroke=\"url(#accentGradient)\" stroke-width=\"2\" opacity=\"0.5\"/>\n  \n  <!-- Coffee cup body -->\n  <g filter=\"url(#shadow)\">\n    <!-- Main cup shape -->\n    <path d=\"M55 75 L60 155 Q65 170 100 170 Q135 170 140 155 L145 75 Z\" fill=\"url(#cupGradient)\"/>\n    \n    <!-- Cup rim -->\n    <ellipse cx=\"100\" cy=\"75\" rx=\"45\" ry=\"10\" fill=\"#5c3d2e\"/>\n    <ellipse cx=\"100\" cy=\"75\" rx=\"42\" ry=\"8\" fill=\"url(#coffeeGradient)\"/>\n    \n    <!-- Inner coffee surface -->\n    <ellipse cx=\"100\" cy=\"78\" rx=\"38\" ry=\"6\" fill=\"#8b5a3c\" opacity=\"0.8\"/>\n    \n    <!-- Cup handle -->\n    <path d=\"M145 90 Q175 95 175 120 Q175 145 145 145\" fill=\"none\" stroke=\"url(#cupGradient)\" stroke-width=\"12\" stroke-linecap=\"round\"/>\n  </g>\n  \n  <!-- Decorative coffee bean on cup -->\n  <g transform=\"translate(100, 125)\">\n    <ellipse cx=\"0\" cy=\"0\" rx=\"15\" ry=\"22\" fill=\"#d4a574\" opacity=\"0.3\"/>\n    <path d=\"M0 -18 Q-5 0 0 18\" fill=\"none\" stroke=\"#5c3d2e\" stroke-width=\"1.5\" opacity=\"0.4\"/>\n  </g>\n  \n  <!-- Steam lines -->\n  <g opacity=\"0.6\">\n    <path d=\"M80 55 Q75 45 80 35 Q85 25 80 15\" fill=\"none\" stroke=\"url(#steamGradient)\" stroke-width=\"4\" stroke-linecap=\"round\">\n      <animate attributeName=\"d\" \n        values=\"M80 55 Q75 45 80 35 Q85 25 80 15;M80 55 Q85 45 80 35 Q75 25 80 15;M80 55 Q75 45 80 35 Q85 25 80 15\" \n        dur=\"2s\" repeatCount=\"indefinite\"/>\n      <animate attributeName=\"opacity\" values=\"0.6;0.3;0.6\" dur=\"2s\" repeatCount=\"indefinite\"/>\n    </path>\n    \n    <path d=\"M100 50 Q95 38 100 28 Q105 18 100 8\" fill=\"none\" stroke=\"url(#steamGradient)\" stroke-width=\"4\" stroke-linecap=\"round\">\n      <animate attributeName=\"d\" \n        values=\"M100 50 Q95 38 100 28 Q105 18 100 8;M100 50 Q105 38 100 28 Q95 18 100 8;M100 50 Q95 38 100 28 Q105 18 100 8\" \n        dur=\"2.5s\" repeatCount=\"indefinite\"/>\n      <animate attributeName=\"opacity\" values=\"0.5;0.8;0.5\" dur=\"2.5s\" repeatCount=\"indefinite\"/>\n    </path>\n    \n    <path d=\"M120 55 Q125 45 120 35 Q115 25 120 15\" fill=\"none\" stroke=\"url(#steamGradient)\" stroke-width=\"4\" stroke-linecap=\"round\">\n      <animate attributeName=\"d\" \n        values=\"M120 55 Q125 45 120 35 Q115 25 120 15;M120 55 Q115 45 120 35 Q125 25 120 15;M120 55 Q125 45 120 35 Q115 25 120 15\" \n        dur=\"1.8s\" repeatCount=\"indefinite\"/>\n      <animate attributeName=\"opacity\" values=\"0.7;0.4;0.7\" dur=\"1.8s\" repeatCount=\"indefinite\"/>\n    </path>\n  </g>\n  \n  <!-- Decorative elements around the circle -->\n  <g fill=\"#d4a574\" opacity=\"0.6\">\n    <!-- Coffee beans scattered -->\n    <ellipse cx=\"35\" cy=\"60\" rx=\"4\" ry=\"6\" transform=\"rotate(-30 35 60)\"/>\n    <ellipse cx=\"165\" cy=\"60\" rx=\"4\" ry=\"6\" transform=\"rotate(30 165 60)\"/>\n    <ellipse cx=\"30\" cy=\"140\" rx=\"4\" ry=\"6\" transform=\"rotate(20 30 140)\"/>\n    <ellipse cx=\"170\" cy=\"140\" rx=\"4\" ry=\"6\" transform=\"rotate(-20 170 140)\"/>\n    <ellipse cx=\"50\" cy=\"175\" rx=\"3\" ry=\"5\" transform=\"rotate(-10 50 175)\"/>\n    <ellipse cx=\"150\" cy=\"175\" rx=\"3\" ry=\"5\" transform=\"rotate(10 150 175)\"/>\n  </g>\n  \n  <!-- Small decorative dots -->\n  <g fill=\"#d4a574\" opacity=\"0.4\">\n    <circle cx=\"45\" cy=\"95\" r=\"2\"/>\n    <circle cx=\"155\" cy=\"95\" r=\"2\"/>\n    <circle cx=\"60\" cy=\"165\" r=\"1.5\"/>\n    <circle cx=\"140\" cy=\"165\" r=\"1.5\"/>\n  </g>\n  \n  <!-- Center highlight on cup -->\n  <ellipse cx=\"85\" cy=\"90\" rx=\"8\" ry=\"4\" fill=\"white\" opacity=\"0.15\"/>\n</svg>",
      "version": 1,
      "createdAt": "2026-03-06T07:33:42.315Z",
      "updatedAt": "2026-03-06T07:33:42.315Z"
