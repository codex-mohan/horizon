    {
      "id": "artifact-1772782282499-29ltla",
      "threadId": "a66c0d2e-6e8a-4e67-9e61-4c084284adba",
      "title": "Artisan Coffee Shop Landing Page",
      "fileName": "coffee-shop.html",
      "type": "html",
      "content": "<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n    <title>Ember & Grind - Artisan Coffee</title>\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\" />\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin />\n    <link\n      href=\"https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@300;400;500;600&display=swap\"\n      rel=\"stylesheet\"\n    />\n    <style>\n      * {\n        margin: 0;\n        padding: 0;\n        box-sizing: border-box;\n      }\n\n      :root {\n        --coffee-dark: #2c1810;\n        --coffee-medium: #5c3d2e;\n        --coffee-light: #8b5a3c;\n        --cream: #f5f0e8;\n        --cream-dark: #e8dcc8;\n        --accent: #d4a574;\n        --accent-light: #e8c4a0;\n        --text-dark: #1a1a1a;\n        --text-muted: #6b6b6b;\n      }\n\n      html {\n        scroll-behavior: smooth;\n      }\n\n      body {\n        font-family: \"Inter\", sans-serif;\n        background-color: var(--cream);\n        color: var(--text-dark);\n        line-height: 1.6;\n      }\n\n      h1,\n      h2,\n      h3,\n      h4 {\n        font-family: \"Playfair Display\", serif;\n      }\n\n      /* Navigation */\n      nav {\n        position: fixed;\n        top: 0;\n        left: 0;\n        right: 0;\n        padding: 1.25rem 5%;\n        display: flex;\n        justify-content: space-between;\n        align-items: center;\n        z-index: 1000;\n        background: rgba(245, 240, 232, 0.95);\n        backdrop-filter: blur(10px);\n        border-bottom: 1px solid rgba(92, 61, 46, 0.1);\n      }\n\n      .logo {\n        font-family: \"Playfair Display\", serif;\n        font-size: 1.5rem;\n        font-weight: 700;\n        color: var(--coffee-dark);\n        display: flex;\n        align-items: center;\n        gap: 0.5rem;\n      }\n\n      .logo-icon {\n        width: 32px;\n        height: 32px;\n        background: linear-gradient(135deg, var(--coffee-medium), var(--coffee-light));\n        border-radius: 50%;\n        position: relative;\n      }\n\n      .logo-icon::after {\n        content: \"\";\n        position: absolute;\n        top: 50%;\n        left: 50%;\n        transform: translate(-50%, -50%);\n        width: 12px;\n        height: 12px;\n        background: var(--cream);\n        border-radius: 50%;\n      }\n\n      .nav-links {\n        display: flex;\n        gap: 2.5rem;\n        list-style: none;\n      }\n\n      .nav-links a {\n        text-decoration: none;\n        color: var(--coffee-medium);\n        font-weight: 500;\n        font-size: 0.95rem;\n        transition: color 0.3s ease;\n      }\n\n      .nav-links a:hover {\n        color: var(--accent);\n      }\n\n      .nav-cta {\n        background: var(--coffee-dark);\n        color: var(--cream) !important;\n        padding: 0.75rem 1.5rem;\n        border-radius: 50px;\n        transition: all 0.3s ease !important;\n      }\n\n      .nav-cta:hover {\n        background: var(--coffee-medium);\n        transform: translateY(-2px);\n      }\n\n      /* Hero Section */\n      .hero {\n        min-height: 100vh;\n        display: flex;\n        align-items: center;\n        padding: 8rem 5% 4rem;\n        background: linear-gradient(135deg, var(--cream) 0%, var(--cream-dark) 100%);\n        position: relative;\n        overflow: hidden;\n      }\n\n      .hero::before {\n        content: \"\";\n        position: absolute;\n        top: -50%;\n        right: -20%;\n        width: 80%;\n        height: 150%;\n        background: radial-gradient(ellipse, rgba(212, 165, 116, 0.15) 0%, transparent 70%);\n        pointer-events: none;\n      }\n\n      .hero-content {\n        max-width: 1400px;\n        margin: 0 auto;\n        display: grid;\n        grid-template-columns: 1fr 1fr;\n        gap: 4rem;\n        align-items: center;\n        width: 100%;\n      }\n\n      .hero-text h1 {\n        font-size: 4.5rem;\n        line-height: 1.1;\n        margin-bottom: 1.5rem;\n        color: var(--coffee-dark);\n      }\n\n      .hero-text h1 span {\n        color: var(--coffee-light);\n        font-style: italic;\n      }\n\n      .hero-text p {\n        font-size: 1.2rem;\n        color: var(--text-muted);\n        margin-bottom: 2.5rem;\n        max-width: 500px;\n      }\n\n      .hero-buttons {\n        display: flex;\n        gap: 1rem;\n        flex-wrap: wrap;\n      }\n\n      .btn {\n        padding: 1rem 2rem;\n        border-radius: 50px;\n        font-weight: 600;\n        text-decoration: none;\n        display: inline-flex;\n        align-items: center;\n        gap: 0.5rem;\n        transition: all 0.3s ease;\n        cursor: pointer;\n        border: none;\n        font-size: 1rem;\n      }\n\n      .btn-primary {\n        background: linear-gradient(135deg, var(--coffee-dark), var(--coffee-medium));\n        color: var(--cream);\n        box-shadow: 0 4px 20px rgba(44, 24, 16, 0.3);\n      }\n\n      .btn-primary:hover {\n        transform: translateY(-3px);\n        box-shadow: 0 8px 30px rgba(44, 24, 16, 0.4);\n      }\n\n      .btn-secondary {\n        background: transparent;\n        color: var(--coffee-dark);\n        border: 2px solid var(--coffee-dark);\n      }\n\n      .btn-secondary:hover {\n        background: var(--coffee-dark);\n        color: var(--cream);\n      }\n\n      .hero-image {\n        position: relative;\n        display: flex;\n        justify-content: center;\n      }\n\n      .coffee-cup {\n        width: 400px;\n        height: 500px;\n        background: linear-gradient(180deg, var(--coffee-dark) 0%, var(--coffee-medium) 100%);\n        border-radius: 20px 20px 80px 80px;\n        position: relative;\n        box-shadow: 0 30px 60px rgba(44, 24, 16, 0.3);\n      }\n\n      .coffee-cup::before {\n        content: \"\";\n        position: absolute;\n        top: 30px;\n        left: 30px;\n        right: 30px;\n        bottom: 100px;\n        background: linear-gradient(180deg, rgba(139, 90, 60, 0.8) 0%, rgba(92, 61, 46, 0.9) 100%);\n        border-radius: 10px 10px 60px 60px;\n      }\n\n      .steam {\n        position: absolute;\n        top: -60px;\n        left: 50%;\n        transform: translateX(-50%);\n        display: flex;\n        gap: 20px;\n      }\n\n      .steam-line {\n        width: 3px;\n        height: 80px;\n        background: linear-gradient(180deg, transparent, rgba(255, 255, 255, 0.3), transparent);\n        border-radius: 50px;\n        animation: steam 2s ease-in-out infinite;\n      }\n\n      .steam-line:nth-child(2) {\n        animation-delay: 0.3s;\n        height: 100px;\n      }\n      .steam-line:nth-child(3) {\n        animation-delay: 0.6s;\n        height: 70px;\n      }\n\n      @keyframes steam {\n        0%,\n        100% {\n          transform: translateY(0) scaleY(1);\n          opacity: 0;\n        }\n        50% {\n          transform: translateY(-20px) scaleY(1.2);\n          opacity: 1;\n        }\n      }\n\n      .cup-handle {\n        position: absolute;\n        right: -60px;\n        top: 100px;\n        width: 80px;\n        height: 150px;\n        border: 15px solid var(--coffee-medium);\n        border-left: none;\n        border-radius: 0 100px 100px 0;\n      }\n\n      /* Features Section */\n      .features {\n        padding: 6rem 5%;\n        background: var(--coffee-dark);\n        position: relative;\n      }\n\n      .features-grid {\n        max-width: 1400px;\n        margin: 0 auto;\n        display: grid;\n        grid-template-columns: repeat(4, 1fr);\n        gap: 2rem;\n      }\n\n      .feature-card {\n        text-align: center;\n        padding: 2.5rem 1.5rem;\n        background: rgba(255, 255, 255, 0.05);\n        border-radius: 20px;\n        transition: all 0.3s ease;\n      }\n\n      .feature-card:hover {\n        background: rgba(255, 255, 255, 0.1);\n        transform: translateY(-5px);\n      }\n\n      .feature-icon {\n        width: 70px;\n        height: 70px;\n        background: linear-gradient(135deg, var(--accent), var(--accent-light));\n        border-radius: 50%;\n        margin: 0 auto 1.5rem;\n        display: flex;\n        align-items: center;\n        justify-content: center;\n        font-size: 2rem;\n      }\n\n      .feature-card h3 {\n        color: var(--cream);\n        font-size: 1.25rem;\n        margin-bottom: 0.75rem;\n      }\n\n      .feature-card p {\n        color: rgba(245, 240, 232, 0.7);\n        font-size: 0.95rem;\n      }\n\n      /* Menu Section */\n      .menu {\n        padding: 6rem 5%;\n        background: var(--cream);\n      }\n\n      .section-header {\n        text-align: center;\n        margin-bottom: 4rem;\n      }\n\n      .section-header h2 {\n        font-size: 3rem;\n        color: var(--coffee-dark);\n        margin-bottom: 1rem;\n      }\n\n      .section-header p {\n        color: var(--text-muted);\n        font-size: 1.1rem;\n        max-width: 600px;\n        margin: 0 auto;\n      }\n\n      .menu-grid {\n        max-width: 1200px;\n        margin: 0 auto;\n        display: grid;\n        grid-template-columns: repeat(3, 1fr);\n        gap: 2rem;\n      }\n\n      .menu-item {\n        background: white;\n        border-radius: 20px;\n        overflow: hidden;\n        box-shadow: 0 10px 40px rgba(44, 24, 16, 0.08);\n        transition: all 0.3s ease;\n      }\n\n      .menu-item:hover {\n        transform: translateY(-10px);\n        box-shadow: 0 20px 50px rgba(44, 24, 16, 0.15);\n      }\n\n      .menu-image {\n        height: 200px;\n        background: linear-gradient(135deg, var(--accent-light), var(--coffee-light));\n        display: flex;\n        align-items: center;\n        justify-content: center;\n        font-size: 4rem;\n      }\n\n      .menu-content {\n        padding: 1.5rem;\n      }\n\n      .menu-content h3 {\n        font-size: 1.25rem;\n        color: var(--coffee-dark);\n        margin-bottom: 0.5rem;\n      }\n\n      .menu-content p {\n        color: var(--text-muted);\n        font-size: 0.9rem;\n        margin-bottom: 1rem;\n      }\n\n      .menu-footer {\n        display: flex;\n        justify-content: space-between;\n        align-items: center;\n      }\n\n      .price {\n        font-family: \"Playfair Display\", serif;\n        font-size: 1.5rem;\n        color: var(--coffee-light);\n        font-weight: 600;\n      }\n\n      .menu-btn {\n        background: var(--coffee-dark);\n        color: var(--cream);\n        border: none;\n        padding: 0.5rem 1.25rem;\n        border-radius: 50px;\n        cursor: pointer;\n        font-weight: 500;\n        transition: all 0.3s ease;\n      }\n\n      .menu-btn:hover {\n        background: var(--coffee-medium);\n      }\n\n      /* About Section */\n      .about {\n        padding: 6rem 5%;\n        background: linear-gradient(135deg, var(--cream-dark), var(--cream));\n      }\n\n      .about-content {\n        max-width: 1400px;\n        margin: 0 auto;\n        display: grid;\n        grid-template-columns: 1fr 1fr;\n        gap: 4rem;\n        align-items: center;\n      }\n\n      .about-images {\n        display: grid;\n        grid-template-columns: 1fr 1fr;\n        gap: 1rem;\n      }\n\n      .about-img {\n        aspect-ratio: 1;\n        background: linear-gradient(135deg, var(--coffee-medium), var(--coffee-light));\n        border-radius: 20px;\n        display: flex;\n        align-items: center;\n        justify-content: center;\n        font-size: 3rem;\n      }\n\n      .about-img:first-child {\n        grid-row: span 2;\n        aspect-ratio: auto;\n      }\n\n      .about-text h2 {\n        font-size: 3rem;\n        color: var(--coffee-dark);\n        margin-bottom: 1.5rem;\n      }\n\n      .about-text p {\n        color: var(--text-muted);\n        margin-bottom: 1.5rem;\n        font-size: 1.05rem;\n      }\n\n      .stats {\n        display: flex;\n        gap: 3rem;\n        margin-top: 2rem;\n      }\n\n      .stat {\n        text-align: center;\n      }\n\n      .stat-number {\n        font-family: \"Playfair Display\", serif;\n        font-size: 2.5rem;\n        color: var(--coffee-light);\n        font-weight: 700;\n      }\n\n      .stat-label {\n        color: var(--text-muted);\n        font-size: 0.9rem;\n      }\n\n      /* Testimonials */\n      .testimonials {\n        padding: 6rem 5%;\n        background: var(--coffee-dark);\n      }\n\n      .testimonials-grid {\n        max-width: 1200px;\n        margin: 0 auto;\n        display: grid;\n        grid-template-columns: repeat(3, 1fr);\n        gap: 2rem;\n      }\n\n      .testimonial {\n        background: rgba(255, 255, 255, 0.05);\n        padding: 2rem;\n        border-radius: 20px;\n        border: 1px solid rgba(255, 255, 255, 0.1);\n      }\n\n      .testimonial-text {\n        color: rgba(245, 240, 232, 0.9);\n        font-style: italic;\n        margin-bottom: 1.5rem;\n        font-size: 1rem;\n        line-height: 1.8;\n      }\n\n      .testimonial-author {\n        display: flex;\n        align-items: center;\n        gap: 1rem;\n      }\n\n      .author-avatar {\n        width: 50px;\n        height: 50px;\n        background: linear-gradient(135deg, var(--accent), var(--coffee-light));\n        border-radius: 50%;\n        display: flex;\n        align-items: center;\n        justify-content: center;\n        font-weight: 600;\n        color: white;\n      }\n\n      .author-name {\n        color: var(--cream);\n        font-weight: 600;\n      }\n\n      .author-role {\n        color: var(--accent);\n        font-size: 0.85rem;\n      }\n\n      .stars {\n        color: var(--accent);\n        margin-bottom: 1rem;\n        font-size: 1rem;\n      }\n\n      /* Contact Section */\n      .contact {\n        padding: 6rem 5%;\n        background: var(--cream);\n      }\n\n      .contact-content {\n        max-width: 1200px;\n        margin: 0 auto;\n        display: grid;\n        grid-template-columns: 1fr 1fr;\n        gap: 4rem;\n      }\n\n      .contact-info h2 {\n        font-size: 3rem;\n        color: var(--coffee-dark);\n        margin-bottom: 1.5rem;\n      }\n\n      .contact-info p {\n        color: var(--text-muted);\n        margin-bottom: 2rem;\n      }\n\n      .contact-details {\n        display: flex;\n        flex-direction: column;\n        gap: 1.5rem;\n      }\n\n      .contact-item {\n        display: flex;\n        align-items: center;\n        gap: 1rem;\n      }\n\n      .contact-icon {\n        width: 50px;\n        height: 50px;\n        background: linear-gradient(135deg, var(--coffee-dark), var(--coffee-medium));\n        border-radius: 50%;\n        display: flex;\n        align-items: center;\n        justify-content: center;\n        font-size: 1.25rem;\n        flex-shrink: 0;\n      }\n\n      .contact-item h4 {\n        color: var(--coffee-dark);\n        margin-bottom: 0.25rem;\n      }\n\n      .contact-item span {\n        color: var(--text-muted);\n      }\n\n      .contact-form {\n        background: white;\n        padding: 2.5rem;\n        border-radius: 20px;\n        box-shadow: 0 10px 40px rgba(44, 24, 16, 0.08);\n      }\n\n      .form-group {\n        margin-bottom: 1.5rem;\n      }\n\n      .form-group label {\n        display: block;\n        color: var(--coffee-dark);\n        margin-bottom: 0.5rem;\n        font-weight: 500;\n      }\n\n      .form-group input,\n      .form-group textarea {\n        width: 100%;\n        padding: 1rem;\n        border: 2px solid var(--cream-dark);\n        border-radius: 10px;\n        font-family: \"Inter\", sans-serif;\n        font-size: 1rem;\n        transition: border-color 0.3s ease;\n      }\n\n      .form-group input:focus,\n      .form-group textarea:focus {\n        outline: none;\n        border-color: var(--accent);\n      }\n\n      .form-group textarea {\n        resize: vertical;\n        min-height: 120px;\n      }\n\n      /* Footer */\n      footer {\n        background: var(--coffee-dark);\n        color: var(--cream);\n        padding: 3rem 5% 1.5rem;\n      }\n\n      .footer-content {\n        max-width: 1400px;\n        margin: 0 auto;\n        display: grid;\n        grid-template-columns: 2fr 1fr 1fr 1fr;\n        gap: 3rem;\n        margin-bottom: 2rem;\n      }\n\n      .footer-brand p {\n        color: rgba(245, 240, 232, 0.7);\n        margin-top: 1rem;\n        font-size: 0.95rem;\n      }\n\n      .footer-links h4 {\n        color: var(--cream);\n        margin-bottom: 1.5rem;\n        font-size: 1.1rem;\n      }\n\n      .footer-links ul {\n        list-style: none;\n      }\n\n      .footer-links li {\n        margin-bottom: 0.75rem;\n      }\n\n      .footer-links a {\n        color: rgba(245, 240, 232, 0.7);\n        text-decoration: none;\n        transition: color 0.3s ease;\n      }\n\n      .footer-links a:hover {\n        color: var(--accent);\n      }\n\n      .social-links {\n        display: flex;\n        gap: 1rem;\n        margin-top: 1rem;\n      }\n\n      .social-link {\n        width: 40px;\n        height: 40px;\n        background: rgba(255, 255, 255, 0.1);\n        border-radius: 50%;\n        display: flex;\n        align-items: center;\n        justify-content: center;\n        text-decoration: none;\n        transition: all 0.3s ease;\n      }\n\n      .social-link:hover {\n        background: var(--accent);\n      }\n\n      .footer-bottom {\n        border-top: 1px solid rgba(255, 255, 255, 0.1);\n        padding-top: 1.5rem;\n        text-align: center;\n        color: rgba(245, 240, 232, 0.5);\n        font-size: 0.9rem;\n      }\n\n      /* Responsive */\n      @media (max-width: 1024px) {\n        .hero-content {\n          grid-template-columns: 1fr;\n          text-align: center;\n        }\n\n        .hero-text p {\n          margin: 0 auto 2.5rem;\n        }\n\n        .hero-buttons {\n          justify-content: center;\n        }\n\n        .hero-image {\n          display: none;\n        }\n\n        .features-grid {\n          grid-template-columns: repeat(2, 1fr);\n        }\n\n        .menu-grid {\n          grid-template-columns: repeat(2, 1fr);\n        }\n\n        .about-content {\n          grid-template-columns: 1fr;\n        }\n\n        .testimonials-grid {\n          grid-template-columns: 1fr;\n        }\n\n        .contact-content {\n          grid-template-columns: 1fr;\n        }\n\n        .footer-content {\n          grid-template-columns: 1fr 1fr;\n        }\n      }\n\n      @media (max-width: 768px) {\n        .nav-links {\n          display: none;\n        }\n\n        .hero-text h1 {\n          font-size: 3rem;\n        }\n\n        .features-grid {\n          grid-template-columns: 1fr;\n        }\n\n        .menu-grid {\n          grid-template-columns: 1fr;\n        }\n\n        .stats {\n          justify-content: center;\n        }\n\n        .footer-content {\n          grid-template-columns: 1fr;\n          text-align: center;\n        }\n      }\n    </style>\n  </head>\n  <body>\n    <!-- Navigation -->\n    <nav>\n      <div class=\"logo\">\n        <div class=\"logo-icon\"></div>\n        Ember & Grind\n      </div>\n      <ul class=\"nav-links\">\n        <li><a href=\"#home\">Home</a></li>\n        <li><a href=\"#menu\">Menu</a></li>\n        <li><a href=\"#about\">About</a></li>\n        <li><a href=\"#contact\">Contact</a></li>\n        <li><a href=\"#contact\" class=\"nav-cta\">Order Now</a></li>\n      </ul>\n    </nav>\n\n    <!-- Hero Section -->\n    <section class=\"hero\" id=\"home\">\n      <div class=\"hero-content\">\n        <div class=\"hero-text\">\n          <h1>Crafted with <span>Passion</span>, Served with Heart</h1>\n          <p>\n            Experience the art of specialty coffee. Every cup tells a story of carefully sourced\n            beans, expert roasting, and barista craftsmanship.\n          </p>\n          <div class=\"hero-buttons\">\n            <a href=\"#menu\" class=\"btn btn-primary\"> ☕ Explore Menu </a>\n            <a href=\"#about\" class=\"btn btn-secondary\"> Our Story </a>\n          </div>\n        </div>\n        <div class=\"hero-image\">\n          <div class=\"coffee-cup\">\n            <div class=\"steam\">\n              <div class=\"steam-line\"></div>\n              <div class=\"steam-line\"></div>\n              <div class=\"steam-line\"></div>\n            </div>\n            <div class=\"cup-handle\"></div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <!-- Features Section -->\n    <section class=\"features\">\n      <div class=\"features-grid\">\n        <div class=\"feature-card\">\n          <div class=\"feature-icon\">🌿</div>\n          <h3>Ethically Sourced</h3>\n          <p>\n            Direct trade relationships with farmers who share our commitment to quality and\n            sustainability.\n          </p>\n        </div>\n        <div class=\"feature-card\">\n          <div class=\"feature-icon\">🔥</div>\n          <h3>Fresh Roasted</h3>\n          <p>Small-batch roasting ensures every bean reaches its peak flavor potential.</p>\n        </div>\n        <div class=\"feature-card\">\n          <div class=\"feature-icon\">👨‍🍳</div>\n          <h3>Expert Baristas</h3>\n          <p>Our trained artisans craft each cup with precision and care.</p>\n        </div>\n        <div class=\"feature-card\">\n          <div class=\"feature-icon\">🌍</div>\n          <h3>Eco Friendly</h3>\n          <p>Compostable packaging and sustainable practices at every step.</p>\n        </div>\n      </div>\n    </section>\n\n    <!-- Menu Section -->\n    <section class=\"menu\" id=\"menu\">\n      <div class=\"section-header\">\n        <h2>Our Favorites</h2>\n        <p>\n          Discover our handcrafted selection of specialty drinks, made with love and the finest\n          ingredients.\n        </p>\n      </div>\n      <div class=\"menu-grid\">\n        <div class=\"menu-item\">\n          <div class=\"menu-image\">☕</div>\n          <div class=\"menu-content\">\n            <h3>Signature Espresso</h3>\n            <p>Rich, bold, and perfectly balanced. A double shot of our house blend.</p>\n            <div class=\"menu-footer\">\n              <span class=\"price\">$4.50</span>\n              <button class=\"menu-btn\">Add to Cart</button>\n            </div>\n          </div>\n        </div>\n        <div class=\"menu-item\">\n          <div class=\"menu-image\">🥛</div>\n          <div class=\"menu-content\">\n            <h3>Velvet Latte</h3>\n            <p>Silky steamed milk meets our signature espresso, topped with microfoam art.</p>\n            <div class=\"menu-footer\">\n              <span class=\"price\">$5.50</span>\n              <button class=\"menu-btn\">Add to Cart</button>\n            </div>\n          </div>\n        </div>\n        <div class=\"menu-item\">\n          <div class=\"menu-image\">🧊</div>\n          <div class=\"menu-content\">\n            <h3>Cold Brew Cascade</h3>\n            <p>24-hour steeped for smooth, refreshing perfection with subtle chocolate notes.</p>\n            <div class=\"menu-footer\">\n              <span class=\"price\">$5.00</span>\n              <button class=\"menu-btn\">Add to Cart</button>\n            </div>\n          </div>\n        </div>\n        <div class=\"menu-item\">\n          <div class=\"menu-image\">🍯</div>\n          <div class=\"menu-content\">\n            <h3>Honey Oat Latte</h3>\n            <p>Local honey, creamy oat milk, and espresso create pure morning magic.</p>\n            <div class=\"menu-footer\">\n              <span class=\"price\">$6.50</span>\n              <button class=\"menu-btn\">Add to Cart</button>\n            </div>\n          </div>\n        </div>\n        <div class=\"menu-item\">\n          <div class=\"menu-image\">🍫</div>\n          <div class=\"menu-content\">\n            <h3>Mocha Bliss</h3>\n            <p>Belgian chocolate meets our house espresso for an indulgent treat.</p>\n            <div class=\"menu-footer\">\n              <span class=\"price\">$6.00</span>\n              <button class=\"menu-btn\">Add to Cart</button>\n            </div>\n          </div>\n        </div>\n        <div class=\"menu-item\">\n          <div class=\"menu-image\">🍵</div>\n          <div class=\"menu-content\">\n            <h3>Matcha Fusion</h3>\n            <p>Ceremonial grade matcha blended with your choice of milk.</p>\n            <div class=\"menu-footer\">\n              <span class=\"price\">$6.50</span>\n              <button class=\"menu-btn\">Add to Cart</button>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <!-- About Section -->\n    <section class=\"about\" id=\"about\">\n      <div class=\"about-content\">\n        <div class=\"about-images\">\n          <div class=\"about-img\">☕</div>\n          <div class=\"about-img\">🫘</div>\n          <div class=\"about-img\">🌿</div>\n        </div>\n        <div class=\"about-text\">\n          <h2>Our Story</h2>\n          <p>\n            Founded in 2018, Ember & Grind began as a passion project between two coffee-obsessed\n            friends. What started as weekend roasting experiments in a tiny garage has blossomed\n            into a beloved neighborhood destination.\n          </p>\n          <p>\n            Every cup we serve represents our commitment to excellence—from sourcing the finest\n            single-origin beans to perfecting our roasting profiles. We believe coffee is more than\n            a beverage; it's an experience that connects people and places.\n          </p>\n          <div class=\"stats\">\n            <div class=\"stat\">\n              <div class=\"stat-number\">12+</div>\n              <div class=\"stat-label\">Origin Countries</div>\n            </div>\n            <div class=\"stat\">\n              <div class=\"stat-number\">50K</div>\n              <div class=\"stat-label\">Happy Customers</div>\n            </div>\n            <div class=\"stat\">\n              <div class=\"stat-number\">6</div>\n              <div class=\"stat-label\">Years of Passion</div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <!-- Testimonials -->\n    <section class=\"testimonials\">\n      <div class=\"section-header\" style=\"margin-bottom: 3rem\">\n        <h2 style=\"color: var(--cream)\">What People Say</h2>\n        <p style=\"color: rgba(245, 240, 232, 0.7)\">\n          Don't just take our word for it—hear from our coffee community.\n        </p>\n      </div>\n      <div class=\"testimonials-grid\">\n        <div class=\"testimonial\">\n          <div class=\"stars\">★★★★★</div>\n          <p class=\"testimonial-text\">\n            \"The best coffee I've ever had. The atmosphere is cozy, the staff is friendly, and every\n            cup is a masterpiece. This is my new morning ritual.\"\n          </p>\n          <div class=\"testimonial-author\">\n            <div class=\"author-avatar\">SK</div>\n            <div>\n              <div class=\"author-name\">Sarah K.</div>\n              <div class=\"author-role\">Regular Customer</div>\n            </div>\n          </div>\n        </div>\n        <div class=\"testimonial\">\n          <div class=\"stars\">★★★★★</div>\n          <p class=\"testimonial-text\">\n            \"As a coffee snob, I'm incredibly picky. Ember & Grind exceeded every expectation. Their\n            single-origin pour-over is absolutely exceptional.\"\n          </p>\n          <div class=\"testimonial-author\">\n            <div class=\"author-avatar\">MJ</div>\n            <div>\n              <div class=\"author-name\">Michael J.</div>\n              <div class=\"author-role\">Coffee Enthusiast</div>\n            </div>\n          </div>\n        </div>\n        <div class=\"testimonial\">\n          <div class=\"stars\">★★★★★</div>\n          <p class=\"testimonial-text\">\n            \"The honey oat latte changed my life. I've been coming here every day for three months\n            and I'm not planning to stop anytime soon.\"\n          </p>\n          <div class=\"testimonial-author\">\n            <div class=\"author-avatar\">EL</div>\n            <div>\n              <div class=\"author-name\">Emily L.</div>\n              <div class=\"author-role\">Verified Local</div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <!-- Contact Section -->\n    <section class=\"contact\" id=\"contact\">\n      <div class=\"contact-content\">\n        <div class=\"contact-info\">\n          <h2>Visit Us</h2>\n          <p>We'd love to see you! Drop by for a cup or reach out for wholesale inquiries.</p>\n          <div class=\"contact-details\">\n            <div class=\"contact-item\">\n              <div class=\"contact-icon\">📍</div>\n              <div>\n                <h4>Location</h4>\n                <span>742 Maple Street, Coffee District</span>\n              </div>\n            </div>\n            <div class=\"contact-item\">\n              <div class=\"contact-icon\">🕐</div>\n              <div>\n                <h4>Hours</h4>\n                <span>Mon-Fri: 6AM-8PM • Sat-Sun: 7AM-9PM</span>\n              </div>\n            </div>\n            <div class=\"contact-item\">\n              <div class=\"contact-icon\">📞</div>\n              <div>\n                <h4>Phone</h4>\n                <span>(555) 123-BREW</span>\n              </div>\n            </div>\n            <div class=\"contact-item\">\n              <div class=\"contact-icon\">✉️</div>\n              <div>\n                <h4>Email</h4>\n                <span>hello@emberandgrind.com</span>\n              </div>\n            </div>\n          </div>\n        </div>\n        <form class=\"contact-form\">\n          <div class=\"form-group\">\n            <label for=\"name\">Your Name</label>\n            <input type=\"text\" id=\"name\" placeholder=\"John Doe\" />\n          </div>\n          <div class=\"form-group\">\n            <label for=\"email\">Email Address</label>\n            <input type=\"email\" id=\"email\" placeholder=\"john@example.com\" />\n          </div>\n          <div class=\"form-group\">\n            <label for=\"message\">Message</label>\n            <textarea id=\"message\" placeholder=\"Tell us what's on your mind...\"></textarea>\n          </div>\n          <button type=\"submit\" class=\"btn btn-primary\" style=\"width: 100%\">Send Message</button>\n        </form>\n      </div>\n    </section>\n\n    <!-- Footer -->\n    <footer>\n      <div class=\"footer-content\">\n        <div class=\"footer-brand\">\n          <div class=\"logo\" style=\"margin-bottom: 1rem\">\n            <div class=\"logo-icon\"></div>\n            Ember & Grind\n          </div>\n          <p>\n            Crafting exceptional coffee experiences since 2018. Every cup, a story worth telling.\n          </p>\n          <div class=\"social-links\">\n            <a href=\"#\" class=\"social-link\">📘</a>\n            <a href=\"#\" class=\"social-link\">📷</a>\n            <a href=\"#\" class=\"social-link\">🐦</a>\n          </div>\n        </div>\n        <div class=\"footer-links\">\n          <h4>Quick Links</h4>\n          <ul>\n            <li><a href=\"#menu\">Menu</a></li>\n            <li><a href=\"#about\">About Us</a></li>\n            <li><a href=\"#contact\">Contact</a></li>\n            <li><a href=\"#\">Careers</a></li>\n          </ul>\n        </div>\n        <div class=\"footer-links\">\n          <h4>Products</h4>\n          <ul>\n            <li><a href=\"#\">Whole Bean</a></li>\n            <li><a href=\"#\">Ground Coffee</a></li>\n            <li><a href=\"#\">Equipment</a></li>\n            <li><a href=\"#\">Gift Cards</a></li>\n          </ul>\n        </div>\n        <div class=\"footer-links\">\n          <h4>Support</h4>\n          <ul>\n            <li><a href=\"#\">FAQ</a></li>\n            <li><a href=\"#\">Shipping</a></li>\n            <li><a href=\"#\">Returns</a></li>\n            <li><a href=\"#\">Privacy</a></li>\n          </ul>\n        </div>\n      </div>\n      <div class=\"footer-bottom\">\n        <p>© 2024 Ember & Grind Coffee Co. All rights reserved. Made with ☕ and ❤️</p>\n      </div>\n    </footer>\n\n    <script>\n      // Smooth scroll for navigation links\n      document.querySelectorAll('a[href^=\"#\"]').forEach((anchor) => {\n        anchor.addEventListener(\"click\", function (e) {\n          e.preventDefault();\n          const target = document.querySelector(this.getAttribute(\"href\"));\n          if (target) {\n            target.scrollIntoView({\n              behavior: \"smooth\",\n              block: \"start\",\n            });\n          }\n        });\n      });\n\n      // Add to cart button interaction\n      document.querySelectorAll(\".menu-btn\").forEach((btn) => {\n        btn.addEventListener(\"click\", function () {\n          const originalText = this.textContent;\n          this.textContent = \"Added! ✓\";\n          this.style.background = \"#d4a574\";\n          setTimeout(() => {\n            this.textContent = originalText;\n            this.style.background = \"\";\n          }, 2000);\n        });\n      });\n\n      // Form submission\n      document.querySelector(\".contact-form\").addEventListener(\"submit\", function (e) {\n        e.preventDefault();\n        const btn = this.querySelector('button[type=\"submit\"]');\n        const originalText = btn.textContent;\n        btn.textContent = \"Message Sent! ✓\";\n        btn.style.background = \"#d4a574\";\n        setTimeout(() => {\n          btn.textContent = originalText;\n          btn.style.background = \"\";\n          this.reset();\n        }, 3000);\n      });\n\n      // Navbar background on scroll\n      window.addEventListener(\"scroll\", function () {\n        const nav = document.querySelector(\"nav\");\n        if (window.scrollY > 50) {\n          nav.style.boxShadow = \"0 4px 20px rgba(44, 24, 16, 0.1)\";\n        } else {\n          nav.style.boxShadow = \"none\";\n        }\n      });\n    </script>\n  </body>\n</html>\n",
      "version": 1,
      "createdAt": "2026-03-06T07:31:22.496Z",
      "updatedAt": "2026-03-06T07:31:22.496Z"
