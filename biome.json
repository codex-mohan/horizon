{
  "$schema": "https://biomejs.dev/schemas/2.3.13/schema.json",
  "files": {
    "includes": [
      "**",
      "!!**/node_modules",
      "!!**/.next",
      "!!**/dist",
      "!!**/build",
      "!!**/.turbo",
      "!!**/.langgraph_api",
      "!!apps/agent/.checkpoints.json",
      "!!apps/agent/.thread-metadata.json",
      "!!apps/agent/data",
      "!!bun.lock",
      "!!**/*.lock",
      "!!**/*.css"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf",
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": {
        "noExcessiveCognitiveComplexity": "off",
        "noForEach": "off"
      },
      "style": {
        "noNestedTernary": "off",
        "useDefaultSwitchClause": "off",
        "noExportedImports": "off",
        "noNonNullAssertion": "off",
        "noParameterAssign": "off"
      },
      "performance": {
        "noBarrelFile": "off",
        "noImgElement": "off"
      },
      "correctness": {
        "useImageSize": "off",
        "noUnusedFunctionParameters": "off",
        "noUnusedImports": "warn"
      },
      "suspicious": {
        "noArrayIndexKey": "off",
        "noExplicitAny": "off",
        "useIterableCallbackReturn": "off",
        "noControlCharactersInRegex": "off"
      },
      "a11y": {
        "noSvgWithoutTitle": "off",
        "noRedundantAlt": "off",
        "useValidAnchor": "off",
        "noStaticElementInteractions": "off",
        "useKeyWithClickEvents": "off",
        "useButtonType": "off",
        "useAriaPropsSupportedByRole": "off",
        "useSemanticElements": "off"
      },
      "security": {
        "noDangerouslySetInnerHtml": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "jsxQuoteStyle": "double",
      "trailingCommas": "es5",
      "semicolons": "always"
    }
  }
}
