{
  "dashboard": {
    "title": "Horizon Chat Metrics",
    "uid": "horizon-chat-metrics",
    "tags": ["horizon", "chat", "sse", "llm"],
    "style": "dark",
    "timezone": "utc",
    "schemaVersion": 39,
    "refresh": "30s",
    "time": { "from": "now-1h", "to": "now" },
    "templating": {
      "list": [
        {
          "name": "datasource",
          "type": "datasource",
          "query": "prometheus",
          "current": { "text": "Prometheus", "value": "prometheus" },
          "hide": 0
        }
      ]
    },
    "panels": [
      {
        "id": 1,
        "title": "Messages Per Minute",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "sum(rate(horizon_chat_requests_total[1m])) * 60",
            "legendFormat": "Messages/min",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "mps",
            "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
          },
          "overrides": []
        }
      },
      {
        "id": 2,
        "title": "Tokens Per Minute (Input / Output)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "sum(rate(horizon_chat_input_tokens_total[1m])) * 60",
            "legendFormat": "Input tokens/min",
            "refId": "A"
          },
          {
            "expr": "sum(rate(horizon_chat_output_tokens_total[1m])) * 60",
            "legendFormat": "Output tokens/min",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "tpm",
            "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
          },
          "overrides": []
        }
      },
      {
        "id": 3,
        "title": "Active SSE Connections",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
        "targets": [
          {
            "expr": "horizon_active_sse_connections",
            "legendFormat": "SSE Connections",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
          },
          "overrides": []
        }
      },
      {
        "id": 4,
        "title": "Model Distribution",
        "type": "piechart",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
        "targets": [
          {
            "expr": "sum(rate(horizon_chat_requests_total[1m])) by (model)",
            "legendFormat": "{{model}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "reqps" },
          "overrides": []
        },
        "options": { "pieType": "donut", "legend": { "displayMode": "list", "placement": "right" } }
      }
    ]
  },
  "overwrite": true
}
