{
  "dashboard": {
    "title": "Horizon Infrastructure",
    "uid": "horizon-infrastructure",
    "tags": ["horizon", "infra", "node", "postgres", "redis"],
    "style": "dark",
    "timezone": "utc",
    "schemaVersion": 39,
    "refresh": "30s",
    "time": { "from": "now-1h", "to": "now" },
    "templating": {
      "list": [
        {
          "name": "datasource",
          "type": "datasource",
          "query": "prometheus",
          "current": { "text": "Prometheus", "value": "prometheus" },
          "hide": 0
        },
        {
          "name": "instance",
          "type": "query",
          "query": "label_values(node_uname_info, instance)",
          "refresh": 1,
          "multi": true,
          "includeAll": true,
          "current": { "text": "All", "value": "$__all" }
        }
      ]
    },
    "panels": [
      {
        "id": 1,
        "title": "CPU Usage",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "100 - (avg by (instance) (irate(node_cpu_seconds_total{mode=\"idle\",instance=~\"$instance\"}[5m])) * 100)",
            "legendFormat": "{{instance}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15 }
          },
          "overrides": []
        }
      },
      {
        "id": 2,
        "title": "Memory Usage",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "100 * (1 - (node_memory_MemAvailable_bytes{instance=~\"$instance\"} / node_memory_MemTotal_bytes{instance=~\"$instance\"}))",
            "legendFormat": "{{instance}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15 }
          },
          "overrides": []
        }
      },
      {
        "id": 3,
        "title": "Postgres Connections",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
        "targets": [
          {
            "expr": "pg_stat_activity_count{instance=~\"$instance\"}",
            "legendFormat": "{{datname}} - {{state}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
          },
          "overrides": []
        }
      },
      {
        "id": 4,
        "title": "Redis Memory Usage",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
        "targets": [
          {
            "expr": "redis_memory_used_bytes{instance=~\"$instance\"}",
            "legendFormat": "Used",
            "refId": "A"
          },
          {
            "expr": "redis_memory_max_bytes{instance=~\"$instance\"}",
            "legendFormat": "Max",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "bytes",
            "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
          },
          "overrides": []
        }
      },
      {
        "id": 5,
        "title": "Disk I/O",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
        "targets": [
          {
            "expr": "irate(node_disk_read_bytes_total{instance=~\"$instance\"}[5m])",
            "legendFormat": "{{instance}} {{device}} read",
            "refId": "A"
          },
          {
            "expr": "irate(node_disk_written_bytes_total{instance=~\"$instance\"}[5m])",
            "legendFormat": "{{instance}} {{device}} write",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "Bps",
            "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
          },
          "overrides": []
        }
      }
    ]
  },
  "overwrite": true
}
