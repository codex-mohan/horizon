{
  "dashboard": {
    "title": "Horizon Sandbox",
    "uid": "horizon-sandbox",
    "tags": ["horizon", "sandbox", "tools", "workers"],
    "style": "dark",
    "timezone": "utc",
    "schemaVersion": 39,
    "refresh": "30s",
    "time": { "from": "now-1h", "to": "now" },
    "templating": {
      "list": [
        {
          "name": "datasource",
          "type": "datasource",
          "query": "prometheus",
          "current": { "text": "Prometheus", "value": "prometheus" },
          "hide": 0
        }
      ]
    },
    "panels": [
      {
        "id": 1,
        "title": "Sandbox Queue Depth",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "horizon_sandbox_queue_depth",
            "legendFormat": "Queue Depth",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "min": 0,
            "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15 }
          },
          "overrides": []
        }
      },
      {
        "id": 2,
        "title": "Execution Duration Histogram",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(horizon_sandbox_execution_duration_seconds_bucket[1m])) by (le))",
            "legendFormat": "p50",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(horizon_sandbox_execution_duration_seconds_bucket[1m])) by (le))",
            "legendFormat": "p95",
            "refId": "B"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(horizon_sandbox_execution_duration_seconds_bucket[1m])) by (le))",
            "legendFormat": "p99",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
          },
          "overrides": []
        }
      },
      {
        "id": 3,
        "title": "Failure Rate by Language",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
        "targets": [
          {
            "expr": "(sum(rate(horizon_tool_executions_total{status=\"error\"}[1m])) by (language) / sum(rate(horizon_tool_executions_total[1m])) by (language)) * 100",
            "legendFormat": "{{language}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15 }
          },
          "overrides": []
        }
      },
      {
        "id": 4,
        "title": "Workers Busy vs Idle",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
        "targets": [
          {
            "expr": "horizon_sandbox_workers_busy",
            "legendFormat": "Busy",
            "refId": "A"
          },
          {
            "expr": "horizon_sandbox_workers_total - horizon_sandbox_workers_busy",
            "legendFormat": "Idle",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15, "stacking": { "mode": "normal" } }
          },
          "overrides": []
        }
      }
    ]
  },
  "overwrite": true
}
