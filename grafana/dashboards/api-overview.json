{
  "dashboard": {
    "title": "Horizon API Overview",
    "uid": "horizon-api-overview",
    "tags": ["horizon", "api", "relay", "http"],
    "style": "dark",
    "timezone": "utc",
    "schemaVersion": 39,
    "refresh": "30s",
    "time": { "from": "now-1h", "to": "now" },
    "templating": {
      "list": [
        {
          "name": "datasource",
          "type": "datasource",
          "query": "prometheus",
          "current": { "text": "Prometheus", "value": "prometheus" },
          "hide": 0
        }
      ]
    },
    "panels": [
      {
        "id": 1,
        "title": "HTTP Request Rate (req/s)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "sum(rate(horizon_http_requests_total[1m]))",
            "legendFormat": "Total",
            "refId": "A"
          },
          {
            "expr": "sum(rate(horizon_http_requests_total[1m])) by (method)",
            "legendFormat": "{{method}}",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
          },
          "overrides": []
        }
      },
      {
        "id": 2,
        "title": "HTTP Latency (p50 / p95 / p99)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(horizon_http_duration_seconds_bucket[1m])) by (le))",
            "legendFormat": "p50",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(horizon_http_duration_seconds_bucket[1m])) by (le))",
            "legendFormat": "p95",
            "refId": "B"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(horizon_http_duration_seconds_bucket[1m])) by (le))",
            "legendFormat": "p99",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
          },
          "overrides": []
        }
      },
      {
        "id": 3,
        "title": "HTTP Error Rate (%)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
        "targets": [
          {
            "expr": "(sum(rate(horizon_http_requests_total{status=~\"4..|5..\"}[1m])) / sum(rate(horizon_http_requests_total[1m]))) * 100",
            "legendFormat": "Error %",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15 }
          },
          "overrides": []
        }
      },
      {
        "id": 4,
        "title": "Status Code Distribution",
        "type": "piechart",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
        "targets": [
          {
            "expr": "sum(rate(horizon_http_requests_total[1m])) by (status)",
            "legendFormat": "{{status}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "reqps" },
          "overrides": []
        },
        "options": { "pieType": "donut", "legend": { "displayMode": "list", "placement": "right" } }
      }
    ]
  },
  "overwrite": true
}
